# Yahoo Mail IMAP
IMAP_HOST=imap.mail.yahoo.com
IMAP_PORT=993
IMAP_USER=your-email@yahoo.com
IMAP_PASSWORD=your-app-password

# School email filtering (comma-separated)
SCHOOL_SENDER_DOMAINS=schooldistrict.org,teacher.school.edu
SCHOOL_SENDER_ADDRESSES=teacher@gmail.com,pto@school.org

# Claude API
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Google Calendar (service account)
GOOGLE_SERVICE_ACCOUNT_EMAIL=kid-cal@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# Twilio SMS
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1234567890
NOTIFICATION_PHONE_NUMBER=+1234567890

# Polling intervals
POLL_INTERVAL_MINUTES=5
REMINDER_CHECK_INTERVAL_MINUTES=15

# Timezone and reminders
TIMEZONE=America/New_York
MORNING_REMINDER_HOUR=7

# Database
DB_PATH=./kid-cal.db

# Logging (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info
